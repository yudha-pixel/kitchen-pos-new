generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Profile {
  id            String    @id @default(uuid()) @db.Uuid
  username      String    @unique
  role          String    @default("cashier")
  password_hash String
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  orders    Order[]
  void_logs OrderVoidLog[]

  @@map("profiles")
}

model Category {
  id         String   @id @default(uuid()) @db.Uuid
  name       String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  products Product[]

  @@map("categories")
}

model Product {
  id             String    @id @default(uuid()) @db.Uuid
  category_id    String?   @db.Uuid
  name           String
  price          Float
  stock_quantity Int       @default(0)
  image_url      String?
  sku            String?   @unique
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  category    Category?   @relation(fields: [category_id], references: [id])
  modifiers   Modifier[]
  order_items OrderItem[]
  void_logs   OrderVoidLog[]

  @@index([category_id])
  @@index([name])
  @@index([sku])
  @@map("products")
}

model Modifier {
  id          String  @id @default(uuid()) @db.Uuid
  product_id  String  @db.Uuid
  name        String
  price_extra Float   @default(0)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@index([product_id])
  @@map("modifiers")
}

model Order {
  id              String    @id @default(uuid()) @db.Uuid
  cashier_id      String?   @db.Uuid
  total_amount    Float
  payment_method  String
  status          String    @default("completed")
  created_at      DateTime  @default(now()) @db.Timestamptz(6)
  table_number    String?
  discount_amount Float     @default(0)
  rounding_amount Float     @default(0)
  notes           String?

  cashier   Profile?      @relation(fields: [cashier_id], references: [id])
  items     OrderItem[]
  void_logs OrderVoidLog[]

  @@index([cashier_id])
  @@index([status])
  @@index([created_at])
  @@index([table_number])
  @@map("orders")
}

model OrderItem {
  id                String  @id @default(uuid()) @db.Uuid
  order_id          String  @db.Uuid
  product_id        String? @db.Uuid
  quantity          Int
  price_at_time     Float
  modifiers_applied Json?   @db.JsonB
  discount_item     Float   @default(0)
  split_group_id    String?
  created_at        DateTime @default(now())

  order   Order    @relation(fields: [order_id], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [product_id], references: [id])

  @@index([order_id])
  @@index([product_id])
  @@index([split_group_id])
  @@map("order_items")
}

model OrderVoidLog {
  id         String  @id @default(uuid()) @db.Uuid
  order_id   String  @db.Uuid
  product_id String? @db.Uuid
  quantity   Int
  reason     String
  cashier_id String? @db.Uuid
  created_at DateTime @default(now()) @db.Timestamptz(6)

  order   Order    @relation(fields: [order_id], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [product_id], references: [id])
  cashier Profile? @relation(fields: [cashier_id], references: [id])

  @@index([order_id])
  @@index([cashier_id])
  @@index([created_at])
  @@map("order_void_logs")
}

model SyncQueue {
  id             String   @id @default(uuid()) @db.Uuid
  operation      String
  table_name     String
  data           Json     @db.JsonB
  status         String   @default("pending")
  error_message  String?
  retry_count    Int      @default(0)
  created_at     DateTime @default(now()) @db.Timestamptz(6)
  synced_at      DateTime? @db.Timestamptz(6)

  @@index([status])
  @@index([table_name])
  @@index([created_at])
  @@map("sync_queue")
}
